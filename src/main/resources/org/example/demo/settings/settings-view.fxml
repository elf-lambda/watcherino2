<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.demo.settings.SettingsController"
      styleClass="app-container"
      spacing="0"
      style="-fx-background-color: #000000;">

    <!-- Header -->
    <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8">
        <Label text="Settings"
               style="-fx-text-fill: #888888; -fx-font-family: 'Consolas'; -fx-font-size: 13px;"/>
    </HBox>

    <!-- Body -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- Left pane: general settings + filters -->
        <VBox spacing="12" style="-fx-padding: 16; -fx-min-width: 260px; -fx-max-width: 260px;"
              VBox.vgrow="ALWAYS">

            <!-- Volume -->
            <Label text="VOLUME"
                   style="-fx-text-fill: #444444; -fx-font-family: 'Consolas'; -fx-font-size: 10px;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Slider fx:id="volumeSlider" min="0" max="1"
                        blockIncrement="0.05" HBox.hgrow="ALWAYS"/>
                <Label fx:id="volumeLabel" text="50%"
                       style="-fx-text-fill: #888888; -fx-font-family: 'Consolas'; -fx-font-size: 12px;"
                       minWidth="40"/>
            </HBox>

            <!-- Piper path -->
            <Label text="PIPER PATH"
                   style="-fx-text-fill: #444444; -fx-font-family: 'Consolas'; -fx-font-size: 10px;"/>
            <HBox spacing="6">
                <TextField fx:id="piperPathField" HBox.hgrow="ALWAYS"
                           promptText="/home/user/.local/bin/piper"/>
                <Button text="…" styleClass="terminal-button" onAction="#onBrowsePiper"
                        minWidth="30"/>
            </HBox>

            <!-- Model path -->
            <Label text="MODEL PATH"
                   style="-fx-text-fill: #444444; -fx-font-family: 'Consolas'; -fx-font-size: 10px;"/>
            <HBox spacing="6">
                <TextField fx:id="modelPathField" HBox.hgrow="ALWAYS"
                           promptText="/home/user/models/model.onnx"/>
                <Button text="…" styleClass="terminal-button" onAction="#onBrowseModel"
                        minWidth="30"/>
            </HBox>

            <!-- Divider -->
            <Separator/>

            <!-- Filter list -->
            <Label text="WORD FILTERS"
                   style="-fx-text-fill: #444444; -fx-font-family: 'Consolas'; -fx-font-size: 10px;"/>

            <ListView fx:id="filterListView" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: #000000; -fx-border-color: #1a1a1a;"/>

            <!-- Add filter -->
            <HBox spacing="6">
                <TextField fx:id="newFilterField" HBox.hgrow="ALWAYS"
                           promptText="Add filter word..."
                           onAction="#onAddFilter"/>
                <Button text="Add" styleClass="terminal-button" onAction="#onAddFilter"/>
            </HBox>

        </VBox>

        <!-- Divider -->
        <Separator orientation="VERTICAL"/>

        <!-- Right pane: channel list -->
        <VBox spacing="6" style="-fx-padding: 16;" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">

            <Label text="CHANNELS"
                   style="-fx-text-fill: #444444; -fx-font-family: 'Consolas'; -fx-font-size: 10px;"/>

            <!-- Filter channels -->
            <TextField fx:id="filterField"
                       promptText="Filter channels..."
                       onKeyReleased="#onFilter"/>

            <!-- Channel ListView -->
            <ListView fx:id="channelListView" VBox.vgrow="ALWAYS"
                      styleClass="channel-list"/>

            <!-- Add channel -->
            <HBox spacing="6">
                <TextField fx:id="newChannelField" HBox.hgrow="ALWAYS"
                           promptText="Add channel..."
                           onAction="#onAddChannel"/>
                <Button text="Add" styleClass="terminal-button" onAction="#onAddChannel"/>
            </HBox>

        </VBox>

    </HBox>

    <!-- Footer -->
    <HBox styleClass="panel-header" alignment="CENTER_RIGHT" spacing="8">
        <Button text="Cancel" styleClass="terminal-button" onAction="#onCancel"/>
        <Button text="Save" styleClass="terminal-button" onAction="#onSave"/>
    </HBox>

</VBox>